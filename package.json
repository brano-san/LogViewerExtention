{
    "name": "jsonlogviewer",
    "displayName": "JsonLogViewer",
    "description": "Просмотр и фильтрация логов из json, с подсветкой уровней",
    "publisher": "branosan",
    "version": "1.1.0",
    "categories": [
        "Other"
    ],
    "engines": {
        "vscode": "^1.78.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/brano-san/LogViewerExtention"
    },
    "activationEvents": [
        "onCommand:logviewer.openLog",
        "onLanguage:logviewer",
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "menus": {
            "editor/context": [
                {
                    "command": "logviewer.filterInclude",
                    "when": "editorHasSelection",
                    "group": "navigation"
                },
                {
                    "command": "logviewer.filterExclude",
                    "when": "editorHasSelection",
                    "group": "navigation"
                }
            ]
        },
        "commands": [
            {
                "command": "logviewer.openLog",
                "title": "LogViewer: Open formatted log"
            },
            {
                "command": "logviewer.processCurrentFile",
                "title": "LogViewer: Format current file"
            },
            {
                "command": "logviewer.filterInclude",
                "title": "Filter Text By Selection"
            },
            {
                "command": "logviewer.filterExclude",
                "title": "Exclude Text By Selection"
            }
        ],
        "configuration": {
            "title": "LogViewer",
            "properties": {
                "logviewer.targetExtensions": {
                    "type": "array",
                    "default": [
                        ".jsonlog",
                        ".json",
                        ".coffin"
                    ],
                    "description": "Список расширений файлов, на которые расширение будет реагировать (например: ['.jsonlog', '.json', '.coffin'])",
                    "items": {
                        "type": "string"
                    }
                },
                "logviewer.colorTrace": {
                    "type": "string",
                    "default": "rgba(255,255,255,0.05)"
                },
                "logviewer.colorDebug": {
                    "type": "string",
                    "default": "rgba(25, 70, 120, 1)"
                },
                "logviewer.colorInfo": {
                    "type": "string",
                    "default": "rgba(0,255,0,0.1)"
                },
                "logviewer.colorWarn": {
                    "type": "string",
                    "default": "rgba(246, 255, 169, 0.5)"
                },
                "logviewer.colorError": {
                    "type": "string",
                    "default": "rgba(176,55,66,0.8)"
                },
                "logviewer.colorCritical": {
                    "type": "string",
                    "default": "rgba(197,15,31,0.8)"
                }
            }
        },
        "languages": [
            {
                "id": "logviewer",
                "aliases": [
                    "LogViewer"
                ],
                "extensions": [
                    ".logviewer"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./"
    },
    "devDependencies": {
        "@types/node": "^14.14.0",
        "@types/vscode": "^1.78.0",
        "typescript": "^4.5.0",
        "vscode-test": "^1.6.1"
    }
}